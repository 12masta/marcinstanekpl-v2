{
  "name": "gatsby-starter-blog",
  "private": true,
  "description": "A starter for a blog powered by Gatsby and Markdown",
  "version": "0.1.0",
  "author": "Kyle Mathews <mathews.kyle@gmail.com>",
  "bugs": {
    "url": "https://github.com/gatsbyjs/gatsby/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.1.3",
    "gatsby": "^5.16.1",
    "gatsby-plugin-feed": "^5.16.0",
    "gatsby-plugin-google-gtag": "^5.16.0",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-manifest": "^5.16.0",
    "gatsby-plugin-offline": "^6.16.0",
    "gatsby-plugin-sharp": "^5.16.0",
    "gatsby-plugin-sitemap": "^6.16.0",
    "gatsby-plugin-slug": "^2.0.0",
    "gatsby-remark-copy-linked-files": "^6.16.0",
    "gatsby-remark-images": "^7.16.0",
    "gatsby-remark-prismjs": "^7.16.0",
    "gatsby-remark-responsive-iframe": "^6.16.0",
    "gatsby-remark-smartypants": "^6.16.0",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-remark": "^6.16.0",
    "gatsby-transformer-sharp": "^5.16.0",
    "prismjs": "^1.25.0",
    "react": "^18.3.1",
    "react-bootstrap": "^2.0.3",
    "react-cookie-consent": "^7.3.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@google/genai": "^1.47.0",
    "@playwright/test": "^1.49.1",
    "gatsby-plugin-purgecss": "^6.2.1",
    "get-port": "^7.1.0",
    "lighthouse": "^8.6.0",
    "playwright": "^1.49.1",
    "playwright-lighthouse": "^2.1.0",
    "prettier": "^2.4.1"
  },
  "homepage": "https://github.com/gatsbyjs/gatsby-starter-blog#readme",
  "keywords": [
    "gatsby"
  ],
  "license": "0BSD",
  "main": "n/a",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gatsbyjs/gatsby-starter-blog.git"
  },
  "scripts": {
    "build": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--disable-warning=DEP0040\" gatsby build",
    "develop": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--disable-warning=DEP0040\" gatsby develop",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "start": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--disable-warning=DEP0040\" gatsby develop",
    "serve": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--disable-warning=DEP0040\" gatsby serve",
    "clean": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--disable-warning=DEP0040\" gatsby clean",
    "test": "npx playwright test --grep-invert=lighthouse --ui",
    "test:seo": "npm run build && CI= npx playwright test tests/features/seo.spec.ts --config=tests/ci.config.ts --project=chromium",
    "test:seo:dev": "npx playwright test tests/features/seo.spec.ts --project=chromium",
    "test-ci": "npm run build && npx playwright test --config=tests/ci.config.ts --grep-invert=lighthouse",
    "test-li": "npx playwright test --config=tests/local.lighthouse.config.ts --grep=lighthouse",
    "test-ci-li": "npx playwright test --config=tests/ci.lighthouse.config.ts --grep=lighthouse",
    "test-all": "npm run test-ci && npm run test-ci-li",
    "lighthouse:smoke": "npm run build && npx playwright test tests/lighthouse.spec.ts --config=tests/ci.lighthouse.config.ts --grep \"Lighthouse - Navbar\"",
    "blog:image": "node tools/blog-image-gen/generate-blog-image.mjs",
    "home:image": "node tools/blog-image-gen/generate-home-image.mjs",
    "about:photo": "node tools/blog-image-gen/process-about-photo.mjs",
    "media:firebase-localize": "node tools/firebase-storage-localize.mjs"
  }
}
